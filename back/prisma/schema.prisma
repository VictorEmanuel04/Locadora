generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum RentalStatus {
  ACTIVE
  EXPIRED
  CANCELED
}

enum MovieAvailability {
  AVAILABLE
  UNAVAILABLE
  COMING_SOON
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String         @map("password_hash")
  role          UserRole       @default(CLIENT)
  rentals       Rental[]
  reviews       Review[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Movie {
  id             String             @id @default(uuid())
  title          String
  synopsis       String
  genre          String
  director       String?
  releaseYear    Int?               @map("release_year")
  durationMinutes Int?              @map("duration_minutes")
  ageRating      String?            @map("age_rating")
  posterUrl      String?            @map("poster_url")
  trailerUrl     String?            @map("trailer_url")
  rentalPrice    Decimal            @db.Decimal(10, 2) @map("rental_price")
  availability   MovieAvailability  @default(AVAILABLE)
  stock          Int                @default(1)
  rentals        Rental[]
  reviews        Review[]
  cartItems      CartItem[]
  wishlistItems  WishlistItem[]
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([genre])
  @@index([availability])
  @@map("movies")
}

model Rental {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  movieId   String       @map("movie_id")
  startsAt  DateTime     @default(now()) @map("starts_at")
  expiresAt DateTime     @map("expires_at")
  status    RentalStatus @default(ACTIVE)
  pricePaid Decimal      @db.Decimal(10, 2) @map("price_paid")
  renewedFromId String?  @map("renewed_from_id")
  renewedFrom   Rental?  @relation("RentalRenewal", fields: [renewedFromId], references: [id])
  renewals      Rental[] @relation("RentalRenewal")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie        @relation(fields: [movieId], references: [id], onDelete: Restrict)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([movieId])
  @@index([expiresAt])
  @@map("rentals")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  movieId   String   @map("movie_id")
  rating    Int
  comment   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, movieId])
  @@index([movieId])
  @@map("reviews")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  movieId   String   @map("movie_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, movieId])
  @@index([userId])
  @@map("cart_items")
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  movieId   String   @map("movie_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie     Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, movieId])
  @@index([userId])
  @@map("wishlist_items")
}
